{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "lib": ["es2022"],
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "#schemas/*": ["./runtime-overlay/schemas-snapshot/*"],
      "#shared-core/*": ["./runtime-overlay/ontology-shared-core/*"],
      "#research/*": ["./runtime-overlay/research-library/*"],
      "~/.claude/schemas/ontology/*": ["./runtime-overlay/schemas-snapshot/ontology/*"]
    }
  },
  "include": [
    "bridge/**/*.ts",
    "lib/**/*.ts",
    "hooks/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
