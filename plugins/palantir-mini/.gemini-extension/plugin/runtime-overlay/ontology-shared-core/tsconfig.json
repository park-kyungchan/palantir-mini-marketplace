{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["bun-types"],
    // sprint-060 W1-cleanup-A: required because re-exported primitive sources
    // (e.g. plugin-manifest.ts) carry sibling `import "./xxx.ts"` paths under
    // bundler resolution. Mirrors ../../.claude/schemas/tsconfig.json.
    // Package is `private: true` Bun workspace — runtime resolution goes
    // through the schemas package directly; this config is verification-only.
    "allowImportingTsExtensions": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
