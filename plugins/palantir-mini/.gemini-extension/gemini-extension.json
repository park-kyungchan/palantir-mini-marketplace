{
  "name": "palantir-mini",
  "version": "6.79.0",
  "description": "Ontology-first control-plane extension for palantir-mini workflows, MCP handlers, hooks, skills, validation, and runtime parity.",
  "mcpServers": {
    "palantir-mini": {
      "command": "bun",
      "args": [
        "run",
        "${extensionPath}${/}plugin${/}bridge${/}mcp-server.ts"
      ],
      "cwd": "${extensionPath}${/}plugin",
      "env": {
        "PALANTIR_MINI_ROOT": "${extensionPath}${/}plugin",
        "PALANTIR_MINI_PLUGIN_ROOT": "${extensionPath}${/}plugin",
        "PLUGIN_ROOT": "${extensionPath}${/}plugin",
        "CLAUDE_PLUGIN_ROOT": "${extensionPath}${/}plugin",
        "PALANTIR_MINI_HOST_RUNTIME": "gemini"
      }
    }
  },
  "contextFileName": "GEMINI.md",
  "plan": {
    "directory": ".gemini/plans"
  }
}
