{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://palantir-mini.local/schemas/layer-boundary.schema.json",
  "title": "LayerBoundaryV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractId",
    "sourceAuthority",
    "llmProvider",
    "runtimeAdapter",
    "pluginSource",
    "projectState",
    "runtimeCache",
    "marketplaceRoot",
    "protectedMutationPolicy",
    "reasonCodes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "palantir-mini/layer-boundary-contract/v1"
    },
    "contractId": {
      "type": "string",
      "minLength": 1
    },
    "sourceAuthority": {
      "$ref": "#/$defs/sourceAuthority"
    },
    "llmProvider": {
      "$ref": "#/$defs/layer"
    },
    "runtimeAdapter": {
      "$ref": "#/$defs/layer"
    },
    "pluginSource": {
      "$ref": "#/$defs/layer"
    },
    "projectState": {
      "$ref": "#/$defs/layer"
    },
    "runtimeCache": {
      "$ref": "#/$defs/layer"
    },
    "marketplaceRoot": {
      "$ref": "#/$defs/layer"
    },
    "protectedMutationPolicy": {
      "$ref": "#/$defs/protectedMutationPolicy"
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/reasonCode"
      }
    }
  },
  "$defs": {
    "sourceAuthority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalMarketplaceRoot",
        "canonicalPluginSource",
        "upstreamMarketplaceSource",
        "upstreamPluginSource",
        "codexRuntimeCache",
        "runtimeBoundaryContract",
        "releasePath"
      ],
      "properties": {
        "canonicalMarketplaceRoot": {
          "type": "string",
          "minLength": 1
        },
        "canonicalPluginSource": {
          "type": "string",
          "minLength": 1
        },
        "upstreamMarketplaceSource": {
          "type": "string",
          "minLength": 1
        },
        "upstreamPluginSource": {
          "type": "string",
          "minLength": 1
        },
        "codexRuntimeCache": {
          "type": "string",
          "pattern": "^~/.codex/plugins/cache/"
        },
        "runtimeBoundaryContract": {
          "type": "string",
          "minLength": 1
        },
        "releasePath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "authority",
        "mutationAuthority",
        "mayAuthorizeProtectedMutation",
        "deterministicForGate",
        "ownedPaths",
        "readOnlyPaths",
        "forbiddenPaths",
        "allowedActions",
        "forbiddenActions",
        "notes"
      ],
      "properties": {
        "role": {
          "enum": [
            "llm-provider",
            "runtime-adapter",
            "plugin-source",
            "project-state",
            "runtime-cache",
            "marketplace-root"
          ]
        },
        "authority": {
          "enum": [
            "metadata-only",
            "runtime-owned",
            "source-of-truth",
            "state-evidence",
            "installed-payload",
            "repository-root"
          ]
        },
        "mutationAuthority": {
          "enum": [
            "none",
            "runtime-owned-state",
            "source-authority",
            "append-only",
            "install-refresh-only"
          ]
        },
        "mayAuthorizeProtectedMutation": {
          "type": "boolean"
        },
        "deterministicForGate": {
          "type": "boolean"
        },
        "ownedPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "readOnlyPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowedActions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "forbiddenActions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "protectedMutationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultDecision",
        "requiredEvidence",
        "nonAuthorizingInputs",
        "blockingReasonCodes"
      ],
      "properties": {
        "defaultDecision": {
          "const": "deny"
        },
        "requiredEvidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "nonAuthorizingInputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "blockingReasonCodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "reasonCode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "deniesProtectedMutation",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^LAYER_BOUNDARY_[A-Z0-9_]+$"
        },
        "severity": {
          "enum": [
            "block",
            "advisory"
          ]
        },
        "deniesProtectedMutation": {
          "type": "boolean"
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
