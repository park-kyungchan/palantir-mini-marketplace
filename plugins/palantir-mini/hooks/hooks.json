{
  "description": "Claude Code hook registry (the Claude-runtime adapter) — auto-loaded by Claude from the plugin's hooks/hooks.json path. Do NOT also reference it from manifest.hooks in plugin.json: the standard hooks/hooks.json loads automatically, so a manifest reference double-loads the same file and fails the hook loader. Maps Claude lifecycle events to the shared runtime-neutral hook logic; the Codex runtime's equivalent registry is hooks/codex-hooks.json.",
  "hooks": {
    "SessionStart": [
      {
        "policyRef": "hook-step:sessionstart-cold-start-governance",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" session-start",
            "timeout": 50,
            "statusMessage": "Session start capture: append session_started and surface eager context when enabled\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      }
    ],
    "UserPromptSubmit": [
      {
        "policyRef": "hook-step:userprompt-front-door",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" prompt-front-door-capture",
            "timeout": 100,
            "statusMessage": "Prompt front door capture: promptId/promptHash \u2192 pm_semantic_intent_gate\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" context-capsule-init",
            "timeout": 100,
            "statusMessage": "Persisting context capsule for prompt-local contract/routing lineage\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "policyRef": "hook-step:pretool-ontology-engineering-workflow",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/ontology-engineering-workflow-enforcement-gate.ts\"",
            "timeout": 40,
            "permissionDecision": "defer",
            "failureMode": "fail-closed",
            "inputSchemaRef": "schemas/hooks/pretooluse.input.schema.json",
            "outputSchemaRef": "schemas/hooks/governance-hook.output.schema.json",
            "statusMessage": "Ontology Engineering workflow gate: FDE provenance + advisory runtime-native question UI\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "*",
        "policyRef": "hook-step:pretool-prompt-dtc-write-gate",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/prompt-dtc-enforcement-gate.ts\"",
            "timeout": 40,
            "permissionDecision": "defer",
            "failureMode": "fail-closed",
            "inputSchemaRef": "schemas/hooks/pretooluse.input.schema.json",
            "outputSchemaRef": "schemas/hooks/governance-hook.output.schema.json",
            "statusMessage": "Prompt-to-DTC write gate (OE-1): re-validates SIC+DTC on the mutation tool set; ontology-write floored to blocking via resolveEffectiveGateMode\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "policyRef": "hook-step:pretool-plugin-ownership",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/agent-ownership-validate.ts\"",
            "if": "Edit(**/plugins/palantir-mini/**)|Write(**/plugins/palantir-mini/**)|MultiEdit(**/plugins/palantir-mini/**)",
            "timeout": 15,
            "permissionDecision": "defer",
            "statusMessage": "rule 07 \u00a7Agent file-ownership gate\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/write-scope-runtime-enforce.ts\"",
            "timeout": 25,
            "permissionDecision": "defer",
            "statusMessage": "write-scope-runtime-enforce: checking subagent writableRoot (canonical plan v2 \u00a74 row 5.7 + rule 16 v4.1.0)\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "policyRef": "hook-step:pretool-edit-governance",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" pre-edit-ontology",
            "if": "Edit(**/ontology/**)",
            "timeout": 50
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" pre-edit-impact-check",
            "if": "!**.test.ts",
            "timeout": 40,
            "async": true,
            "statusMessage": "Checking impact\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" ontology-import-guard",
            "timeout": 25,
            "permissionDecision": "defer",
            "statusMessage": "ontology-import-guard\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" pre-edit-impact-mcp-first",
            "if": "Edit|Write|MultiEdit",
            "timeout": 25,
            "permissionDecision": "defer",
            "failureMode": "fail-closed",
            "inputSchemaRef": "schemas/hooks/pretooluse.input.schema.json",
            "outputSchemaRef": "schemas/hooks/governance-hook.output.schema.json",
            "statusMessage": "MCP-first gate (rule 12 v3.10.0 \u00a7MCP-First protocol; BLOCKING sprint-062 W3-\u03b1)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/ontology-domain-classification-validate.ts\"",
            "if": "Edit|Write|MultiEdit",
            "timeout": 25,
            "permissionDecision": "defer",
            "statusMessage": "6-domain classification marker gate (sprint-062 W3-\u03b1; operating model \u00a74.1)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/lead-ontology-discovery-completeness.ts\"",
            "timeout": 25,
            "async": true,
            "statusMessage": "Downstream ontology discovery completeness advisory (not contract proof)\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "**/schemas/ontology/(primitives|contracts|codegen)/**/*.ts",
        "policyRef": "hook-step:pretool-schema-frontmatter",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" semantic-frontmatter-validate",
            "timeout": 25,
            "decision": "block",
            "statusMessage": "Validating semantic frontmatter\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "mcp__plugin_palantir-mini_palantir-mini__emit_event|mcp__palantir_mini__emit_event|mcp__palantir_mini__.emit_event|mcp__palantir-mini__emit_event|mcp_palantir-mini_emit_event|mcp_palantir_mini_emit_event",
        "policyRef": "hook-step:pretool-emit-event-value",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" value-grade-assigner",
            "timeout": 25,
            "decision": "block",
            "statusMessage": "rule 26 \u00a7Auto-grade \u2014 scoring envelope axes\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "Agent",
        "policyRef": "hook-step:pretool-agent-dispatch",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/researcher-citation-precision.ts\"",
            "timeout": 25,
            "async": true,
            "statusMessage": "Researcher citation-precision advisory (Opus 4.7 multi-source synthesis nudge)\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "policyRef": "hook-step:posttool-edit-propagation",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" post-edit-propagate",
            "if": "Edit(**/src/**)",
            "timeout": 75
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" post-edit-verifier-suggest",
            "if": "Edit|Write|MultiEdit(!**.d.ts|*.test.ts)",
            "timeout": 25,
            "async": true,
            "statusMessage": "Suggesting verifier fan-out\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "**/schemas/ontology/(primitives|contracts|codegen)/**/*.ts",
        "policyRef": "hook-step:posttool-schema-frontmatter",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" semantic-frontmatter-validate",
            "if": "Edit(**/schemas/ontology/**/primitives/**/*.ts)",
            "timeout": 25,
            "async": true,
            "statusMessage": "Checking semantic frontmatter\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "**/MEMORY.md|**/BROWSE.md|**/INDEX.md|**/CLAUDE.md",
        "policyRef": "hook-step:posttool-doc-drift",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" doc-edit-drift",
            "timeout": 50
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "**/src/generated/**",
        "policyRef": "hook-step:posttool-generated-header",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" generated-header-check",
            "if": "Write(**/*.ts)",
            "timeout": 25
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "**/.codex-plugin/plugin.json|**/hooks.json",
        "policyRef": "hook-step:posttool-manifest-validation",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" manifest-validate",
            "timeout": 25
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "mcp__plugin_palantir-mini_palantir-mini__emit_event|mcp__palantir_mini__emit_event|mcp__palantir_mini__.emit_event|mcp__palantir-mini__emit_event|mcp_palantir-mini_emit_event|mcp_palantir_mini_emit_event",
        "policyRef": "hook-step:posttool-emit-event-value",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" emit-event-postdispatch",
            "timeout": 40,
            "async": true,
            "statusMessage": "rule 26 \u2014 emit_event post-dispatch (outcome-pair + memory-layer + T3 circuit + T4 canonical)\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "policyRef": "hook-step:posttool-edit-watch",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/impact-graph-maintain.ts\"",
            "if": "Edit|Write|MultiEdit|NotebookEdit",
            "timeout": 25,
            "async": true,
            "statusMessage": "Marking impact-graph dirty (sprint-061 B.W1 continuous-maintenance)\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "Bash",
        "policyRef": "hook-step:posttool-git-impact-maintenance",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" post-merge-cleanup",
            "timeout": 40,
            "async": true,
            "statusMessage": "Post-merge cleanup (rule 25)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" pre-pr-dirty-gate",
            "if": "Bash(gh pr create*)",
            "timeout": 40,
            "permissionDecision": "defer",
            "statusMessage": "Pre-PR dirty-gate (rule 25 v1.1.0 \u00a7Wave-split policy)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/impact-graph-cascade-delete.ts\"",
            "if": "Bash",
            "timeout": 25,
            "async": true,
            "statusMessage": "Impact-graph cascade-delete (sprint-061 B.W1)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/impact-graph-bulk-refresh.ts\"",
            "if": "Bash",
            "timeout": 40,
            "async": true,
            "statusMessage": "Impact-graph bulk-refresh on git checkout/merge/rebase/pull (sprint-061 B.W1)\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      },
      {
        "matcher": "TaskUpdate",
        "policyRef": "hook-step:posttool-taskupdate-enrichment",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/task-completed-enrichment.ts\"",
            "if": "TaskUpdate",
            "timeout": 25,
            "async": true,
            "statusMessage": "task-completed-enrichment: synthesizing withWhat for completed task (sprint-062 W6-\u03b2 C5; rule 10 5-dim)\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      }
    ],
    "PreCompact": [
      {
        "policyRef": "hook-step:precompact-lineage-integrity",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" pre-compact-state",
            "timeout": 100,
            "decision": "block"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" events-5d-gate",
            "timeout": 75,
            "decision": "block",
            "statusMessage": "Validating 5D conformance\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" rule-audit --mode=bottleneck",
            "timeout": 40,
            "async": true,
            "statusMessage": "rule-audit (bottleneck mode)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" orphan-pair-watchdog",
            "timeout": 25,
            "async": true,
            "statusMessage": "Orphan-pair watchdog (rule 26 \u00a7Axis B1; threshold 5%)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/workflow-trace-leak-detect.ts\"",
            "timeout": 25,
            "async": true,
            "statusMessage": "Workflow trace leak scan (advisory)\u2026"
          }
        ],
        "surfaceStatus": "public-core"
      }
    ],
    "Stop": [
      {
        "policyRef": "hook-step:stop-session-closeout",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" session-end-cleanup",
            "timeout": 40,
            "async": true,
            "statusMessage": "Session-end cleanup (rule 25 v1.1.0)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/impact-graph-session-end-flush.ts\"",
            "timeout": 75,
            "async": true,
            "statusMessage": "Impact-graph session-end flush (sprint-061 B.W1)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/t4-promotion-trigger.ts\"",
            "timeout": 100,
            "async": true,
            "statusMessage": "T4 promotion trigger \u2014 session-end promotion digest (sprint-062 W2-\u03b1)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/bypass-budget-monitor.ts\"",
            "timeout": 40,
            "async": true,
            "statusMessage": "Bypass-budget monitor \u2014 session bypass frequency audit (sprint-062 W3-\u03b1)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/ontology-drift-fold.ts\"",
            "timeout": 40,
            "async": true,
            "statusMessage": "Ontology drift fold \u2014 read-only session drift advisory (Pillar C #3; emit-only, never proposes)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/hooks/second-brain-fold.ts\"",
            "timeout": 120,
            "async": true,
            "statusMessage": "Second-brain memory fold \u2014 fold session transcript into the project knowledge graph; forward verdicts to events.jsonl (advisory, never blocks)\u2026"
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" stop-validate",
            "timeout": 75
          }
        ],
        "surfaceStatus": "public-core"
      }
    ],
    "SubagentStart": [
      {
        "policyRef": "hook-step:subagentstart-briefing",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" subagent-start",
            "timeout": 50,
            "async": true
          }
        ],
        "surfaceStatus": "public-core"
      }
    ],
    "SubagentStop": [
      {
        "policyRef": "hook-step:subagentstop-heartbeat",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" subagent-stop",
            "timeout": 50
          },
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" heartbeat-validate",
            "timeout": 25,
            "async": true
          }
        ],
        "surfaceStatus": "public-core"
      }
    ],
    "PostCompact": [
      {
        "policyRef": "hook-step:postcompact-state-restore",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${CLAUDE_PLUGIN_ROOT}/scripts/run.ts\" post-compact",
            "timeout": 100
          }
        ],
        "surfaceStatus": "public-core"
      }
    ]
  },
  "surfaceStatusSchemaVersion": "palantir-mini/surface-status/v1"
}
