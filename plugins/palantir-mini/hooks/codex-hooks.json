{
  "description": "Codex-native hook entrypoints for palantir-mini. Codex must not parse hooks/hooks.json directly because that shared workflow-intent registry can contain non-Codex fields and file-glob matchers. These regex-safe entrypoints delegate to lib/codex/codex-hook-adapter.ts, which live-reads hooks/hooks.json. PreToolUse is intentionally not registered for Codex until prompt opt-out capture and read-only/review-artifact classification are reliable. SessionStart and UserPromptSubmit are intentionally not registered for Codex.",
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${PLUGIN_ROOT}/lib/codex/codex-hook-adapter.ts\" PermissionRequest",
            "timeout": 225,
            "statusMessage": "palantir-mini Codex adapter: PermissionRequest"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${PLUGIN_ROOT}/lib/codex/codex-hook-adapter.ts\" PostToolUse",
            "timeout": 225,
            "statusMessage": "palantir-mini Codex adapter: PostToolUse"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${PLUGIN_ROOT}/lib/codex/codex-hook-adapter.ts\" PreCompact",
            "timeout": 225,
            "statusMessage": "palantir-mini Codex adapter: PreCompact"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${PLUGIN_ROOT}/lib/codex/codex-hook-adapter.ts\" PostCompact",
            "timeout": 225,
            "statusMessage": "palantir-mini Codex adapter: PostCompact"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${PLUGIN_ROOT}/lib/codex/codex-hook-adapter.ts\" SubagentStart",
            "timeout": 225,
            "statusMessage": "palantir-mini Codex adapter: SubagentStart"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${PLUGIN_ROOT}/lib/codex/codex-hook-adapter.ts\" SubagentStop",
            "timeout": 225,
            "statusMessage": "palantir-mini Codex adapter: SubagentStop"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run \"${PLUGIN_ROOT}/lib/codex/codex-hook-adapter.ts\" Stop",
            "timeout": 225,
            "statusMessage": "palantir-mini Codex adapter: Stop"
          }
        ]
      }
    ]
  }
}
