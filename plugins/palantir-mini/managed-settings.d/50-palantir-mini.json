{
    "description": "palantir-mini per-project RBAC fragment for prompt-to-DTC contract gating, ontology-engineering workflow control, Codex bridge/runtime alignment, and selective-blocking enforcement. Loaded by Claude Code from managed-settings.d/ into the effective permission policy. L1 (allow/deny), L2 (CapabilityToken gate), L3 (MarkingDeclaration sensitivity).",
    "permissions": {
        "allow": [
            "Read(~/.claude/**)",
            "Read(./**)",
            "Edit(~/.claude/rules/**)",
            "Edit(~/.claude/plans/**)",
            "Edit(~/.claude/projects/**)",
            "Edit(./.palantir-mini/plan/**)",
            "Edit(~/.claude/research/BROWSE.md)",
            "Edit(~/.claude/research/INDEX.md)",
            "Edit(~/.claude/research/**/BROWSE.md)",
            "Edit(~/.claude/research/**/INDEX.md)",
            "Edit(~/.claude/CLAUDE.md)",
            "Edit(~/.claude/settings.json)",
            "Edit(~/.claude/settings.local.json)",
            "Write(~/.claude/rules/**)",
            "Write(~/.claude/plans/**)",
            "Write(~/.claude/projects/**)",
            "Write(./.palantir-mini/plan/**)",
            "Write(./.palantir-mini/session/events.jsonl)",
            "Write(./.palantir-mini/session/**)",
            "Write(./.palantir-mini/scenarios/**)",
            "Write(./.palantir-mini/harness/**)",
            "Write(./src/generated/**)",
            "Bash(rm ~/.claude/rules/**)",
            "Bash(rm ~/.claude/plans/**)",
            "Bash(rm ~/.claude/projects/**)",
            "Bash(mv ~/.claude/**)",
            "Bash(cp ~/.claude/**)",
            "Bash(mkdir -p ~/.claude/**)",
            "Bash(bun run ${PALANTIR_MINI_PLUGIN_ROOT}/scripts/*)",
            "Bash(bun run ${PALANTIR_MINI_PLUGIN_ROOT}/lib/rbac/l2-check.ts *)",
            "Bash(bun run ${PALANTIR_MINI_PLUGIN_ROOT}/lib/rbac/l3-check.ts *)",
            "Bash(bun test *)",
            "Bash(bunx tsc *)",
            "mcp__palantir-mini__emit_event",
            "mcp__palantir-mini__events_log_rotate",
            "mcp__palantir-mini__get_ontology",
            "mcp__palantir-mini__ontology_schema_get",
            "mcp__palantir-mini__impact_query",
            "mcp__palantir-mini__pre_edit_impact",
            "mcp__palantir-mini__pm_pre_mutation_governance",
            "mcp__palantir-mini__apply_edit_function",
            "mcp__palantir-mini__commit_edits",
            "mcp__palantir-mini__grade_semantic_intent_contract",
            "mcp__palantir-mini__pm_semantic_intent_gate",
            "mcp__palantir-mini__pm_intent_router",
            "mcp__palantir-mini__pm_ontology_engineering_workflow",
            "mcp__palantir-mini__pm_lead_brief",
            "mcp__palantir-mini__pm_health_audit",
            "mcp__palantir-mini__pm_substrate_query",
            "mcp__palantir-mini__research_context_select",
            "mcp__palantir-mini__research_library_refresh",
            "mcp__palantir-mini__pm_plugin_self_check",
            "mcp__palantir-mini__pm_workflow_response_validate",
            "mcp__palantir-mini__pm_surface_contract_audit",
            "mcp__palantir-mini__pm_aip_source_authority_validate",
            "mcp__palantir-mini__pm_runtime_decision_parity",
            "mcp__palantir-mini__pm_rule_query",
            "mcp__palantir-mini__pm_rule_audit",
            "mcp__palantir-mini__validate_managed_settings_fragments",
            "mcp__palantir-mini__ontology_context_query"
        ],
        "ask": [
            {
                "description": "L2: CapabilityToken gate for ship-merge \u2014 requires valid token with ship-merge scope",
                "rule": "mcp__palantir-mini__commit_edits",
                "condition": "action == 'ship-merge'",
                "preflightScript": "bun run ${PALANTIR_MINI_PLUGIN_ROOT}/lib/rbac/l2-check.ts ${CAPABILITY_TOKEN} ship-merge"
            },
            {
                "description": "L2: CapabilityToken gate for schema-write \u2014 requires valid token with schema-write scope",
                "rule": "Write(~/.claude/schemas/**)",
                "condition": "action == 'schema-write'",
                "preflightScript": "bun run ${PALANTIR_MINI_PLUGIN_ROOT}/lib/rbac/l2-check.ts ${CAPABILITY_TOKEN} schema-write"
            },
            {
                "description": "L2: CapabilityToken gate for ontology-register \u2014 requires valid token with ontology-register scope",
                "rule": "Write(./ontology/**)",
                "condition": "action == 'ontology-register'",
                "preflightScript": "bun run ${PALANTIR_MINI_PLUGIN_ROOT}/lib/rbac/l2-check.ts ${CAPABILITY_TOKEN} ontology-register"
            },
            {
                "description": "L3: MarkingDeclaration sensitivity gate for cell/column reads \u2014 blocks restricted/confidential access without clearance",
                "rule": "mcp__palantir-mini__get_ontology",
                "condition": "domain == 'security'",
                "preflightScript": "bun run ${PALANTIR_MINI_PLUGIN_ROOT}/lib/rbac/l3-check.ts ${COLUMN_OR_CELL} ${SESSION_CLEARANCE:-internal}"
            }
        ],
        "deny": [
            "Write(~/.claude/schemas/ontology/types.ts)",
            "Write(~/.claude/schemas/ontology/semantics.ts)"
        ],
        "surfaceStatusSchemaVersion": "palantir-mini/surface-status/v1",
        "surfaceStatus": "protected-default-off",
        "surfaceToolDecisions": [
            {
                "toolName": "pm_semantic_workbench_state",
                "registryStatus": "keep",
                "surfaceStatus": "internal",
                "reason": "Handler remains plugin-internal until SemanticWorkbenchState is stable; no deletion in PR1."
            },
            {
                "toolName": "pm_semantic_consistency_gate",
                "registryStatus": "register",
                "surfaceStatus": "public-core",
                "reason": "Deterministic semantic consistency promotion gate is planned for later public-core registration; PR1 records the decision only and performs no public MCP exposure or deletion."
            }
        ]
    },
    "env": {
        "PALANTIR_MINI_SESSION_DIR": "./.palantir-mini/session",
        "PALANTIR_MINI_SNAPSHOT_DIR": "./.palantir-mini/session/snapshots",
        "PALANTIR_MINI_EVENTS_FILE": "./.palantir-mini/session/events.jsonl",
        "PALANTIR_MINI_PROMPT_DTC_GATE_MODE": "selective-blocking"
    }
}
