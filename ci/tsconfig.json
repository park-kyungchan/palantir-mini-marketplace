{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "typeRoots": ["../plugins/palantir-mini/node_modules/@types", "../plugins/palantir-mini/node_modules"],
    "lib": ["es2022"],
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["./**/*.ts"]
}
